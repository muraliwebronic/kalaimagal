# ---- Core ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Kalaimagal"
NEXT_PUBLIC_SITE_NAME_TAMIL="கலைமகள்"

# ---- Database ----
DATABASE_URL="mysql://user:password@host:3306/dbname"

# ---- Auth (generate via: openssl rand -base64 32) ----
JWT_SECRET="<your-jwt-secret-here>"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ---- Storage (driver switch) ----
# Dev: ./public/uploads (web-accessible, convenient). Prod MUST use r2.
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./public/uploads
# R2 (prod)
R2_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key>
R2_SECRET_ACCESS_KEY=<your-r2-secret-key>
R2_BUCKET_PDFS=kalaimagal-pdfs
R2_BUCKET_CACHE=kalaimagal-cache
R2_ENDPOINT=<your-r2-endpoint-url>

# ---- Razorpay ----
RAZORPAY_KEY_ID=<your-razorpay-key-id>
RAZORPAY_KEY_SECRET=<your-razorpay-key-secret>
NEXT_PUBLIC_RAZORPAY_KEY_ID=<your-razorpay-key-id>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>

# ---- Email (Nodemailer SMTP) ----
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<smtp-username>
SMTP_PASS=<smtp-password>
EMAIL_FROM="Kalaimagal <hello@kalaimagal.com>"
EMAIL_REPLY_TO=support@kalaimagal.com

# ---- Admin seed (only used by `prisma db seed`) ----
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=<strong-password>
SEED_ADMIN_NAME="Admin"
SEED_FORCE_PASSWORD_CHANGE=true

# ---- Cron (generate via: openssl rand -base64 32) ----
CRON_SECRET="<your-cron-secret-here>"

# ---- Observability ----
SENTRY_DSN=
LOG_LEVEL=info
